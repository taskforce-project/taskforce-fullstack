# ==============================================
# CONFIGURATION ENVIRONNEMENT - TASKFORCE
# ==============================================

# ==============================================
# BASE DE DONNÉES POSTGRESQL
# ==============================================
POSTGRES_DB=taskforce_dev
POSTGRES_USER=taskforce_user
POSTGRES_PASSWORD=taskforce_secure_password_change_me
POSTGRES_PORT=5432

# ==============================================
# BACKEND - SPRING BOOT
# ==============================================
BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# JWT Configuration (Production uniquement)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-256-bits

# ==============================================
# FRONTEND - NEXT.JS
# ==============================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ==============================================
# STRIPE - PAIEMENT
# ==============================================
# Clés API Stripe (Mode Test: pk_test_... / Mode Live: pk_live_...)
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Prix Stripe - Price IDs (commence par price_...)
STRIPE_PRICE_ID_PRO=price_your_pro_plan_id_here

# URLs de redirection après paiement
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# ==============================================
# PGADMIN (Développement uniquement)
# ==============================================
PGADMIN_EMAIL=admin@taskforce.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ==============================================
# NGINX (Production uniquement)
# ==============================================
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# CONFIGURATION ADDITIONNELLE
# ==============================================
# Environnement: dev, staging, prod
ENVIRONMENT=dev

# Timezone
TZ=Europe/Paris
